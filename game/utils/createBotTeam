const Team = require("../models/Team");
const Player = require("../models/Player");
const Manager = require("../models/Manager");

const { generatePlayersForTeam } = require("./playerGenerator");

async function createBotTeam(league){

const botTeam = new Team({

name: "Bot FC " + Math.floor(Math.random()*1000),
shortName: "BOT",

league,
country: "Deutschland",

balance: 0,          // ❗ kein Startgeld
fanBase: 0.8,
homeBonus: 1,

isBot: true

});

await botTeam.save();

/* Spieler generieren */

await generatePlayersForTeam(botTeam);

/* Trainer */

await Manager.create({

team: botTeam._id,

firstName: "Bot",
lastName: "Trainer",

age: 45,

rating: 2,

formation: "4-4-2",

playstyle: ["Ballbesitz","Kontern","Gegenpressing","Mauern"]
[Math.floor(Math.random()*4)]

});

return botTeam;

}

module.exports = { createBotTeam };